# Copia este archivo a .env.local (recomendado) o .env
#
# En Supabase Dashboard → Project Settings → API:
# - NEXT_PUBLIC_SUPABASE_ANON_KEY = clave "anon" / "publishable" (empieza con eyJ... o sb_publishable_...)
#   ⚠️ NUNCA uses la clave "secret" / service_role aquí
# - SUPABASE_SERVICE_ROLE_KEY = solo en servidor, nunca NEXT_PUBLIC_

NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-clave-anon-o-publishable
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Sprint 2 — API-Football (opcional; sin key usa jornada mock en dev)
API_FOOTBALL_KEY=
API_FOOTBALL_LEAGUE_ID=239
API_FOOTBALL_SEASON=2025
# Semestre activo: apertura (ene–jun) o clausura (jul–dic). Si se omite, se infiere del mes.
# API_FOOTBALL_TOURNAMENT_PHASE=clausura

# Protege POST /api/cron/gameweek. Vacío en local OK; obligatorio en producción
# (GitHub Actions workflow gameweek-cron + mismo valor en el host).
# CRON_SECRET=
